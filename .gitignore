# Local environment variables and secrets (CRITICAL for production safety)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
*.env

# Backend specific local databases / logs
*.db
*.sqlite
*.sqlite3
backend/database.db
backend/*.db
backend/*.sqlite

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (CRA / Vite)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-temporary-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-gyp's directory when package is installed
.lock-wscript

# Platforms directories for Cordova/Phonegap
platforms/
plugins/

# Editor / IDE settings (VS Code, WebStorm, etc)
