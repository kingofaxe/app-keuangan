# --- DATABASE CONFIGURATION ---
# Masukkan password database PostgreSQL yang aman di sini.
# DB_PASSWORD digunakan oleh db (PostgreSQL) dan backend agar bisa saling terhubung.
DB_PASSWORD=ganti_dengan_password_db_rahasia_kamu

# --- SECURITY CONFIGURATION ---
# Masukkan string random/acak yang panjang untuk mengamankan JWT Token login.
JWT_SECRET=ganti_dengan_string_random_yang_panjang_dan_aman
